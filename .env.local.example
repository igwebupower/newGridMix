# Sanity Configuration
# Get these values from https://www.sanity.io/manage after creating a project

NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Optional: Sanity token for server-side mutations (not needed for reading)
# SANITY_API_TOKEN=your-api-token

# Existing environment variables
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Watt (AI grid assistant) and the monthly report generator both use this
OPENAI_API_KEY=

# Signs/verifies free self-serve MCP API keys (lib/api-keys.ts). Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
API_KEY_SECRET=
